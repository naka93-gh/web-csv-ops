{
  "name": "web-csv",
  "version": "0.1.0",
  "description": "Parse and stringify CSV in the browser or Node.js. Zero dependencies.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/naka93-gh/web-csv.git"
  },
  "bugs": "https://github.com/naka93-gh/web-csv/issues",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "CHANGELOG.md",
    "!dist/*.min.js",
    "!dist/**/*.map"
  ],
  "sideEffects": false,
  "scripts": {
    "prepare": "tsc -p tsconfig.build.json",
    "build": "tsc -p tsconfig.build.json",
    "build:min": "esbuild src/index.ts --bundle --minify --format=esm --target=es2020 --outfile=dist/index.min.js",
    "size": "pnpm build:min && printf 'min: %s B / gzip: %s B\\n' $(wc -c < dist/index.min.js) $(gzip -c dist/index.min.js | wc -c)",
    "size:check": "node scripts/size.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:dist": "pnpm build && node scripts/smoke.mjs",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "format": "biome format --write .",
    "lint": "biome lint .",
    "check": "biome check --write ."
  },
  "keywords": [
    "csv",
    "parser",
    "browser",
    "typescript",
    "zero-dependency"
  ],
  "author": "naka93-gh",
  "license": "MIT",
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@types/node": "^25.8.0",
    "@vitest/coverage-v8": "4.1.6",
    "esbuild": "^0.28.0",
    "happy-dom": "^20.9.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=22"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
